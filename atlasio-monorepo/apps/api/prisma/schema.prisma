// ─── SSO/SAML2/OIDC ──────────────────────────────────────────────────────────

model SsoProvider {
  id            String        @id @default(cuid())
  tenantId      String        @map("tenant_id")
  name          String // Display name (e.g., "Okta", "Azure AD")
  protocol      SsoProtocol // SAML2, OIDC
  issuer        String // IdP issuer / entityId
  clientId      String?       @map("client_id") // OIDC client ID
  clientSecret  String?       @map("client_secret") // OIDC client secret (encrypted)
  discoveryUrl  String?       @map("discovery_url") // OIDC .well-known URL
  metadataXml   String?       @map("metadata_xml") // SAML IdP metadata XML
  certificate   String? // SAML signing certificate (PEM)
  acsUrl        String?       @map("acs_url") // SAML Assertion Consumer Service URL
  sloUrl        String?       @map("slo_url") // Single Logout URL
  callbackUrl   String?       @map("callback_url") // OIDC redirect URI
  scopes        String?       @default("openid profile email")
  attributeMap  Json?         @map("attribute_map") // Mapping: IdP attrs -> Atlasio fields
  autoProvision Boolean       @default(true) @map("auto_provision") // Auto-create users on first login
  defaultRole   Role          @default(STUDENT) @map("default_role")
  enabled       Boolean       @default(true)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  Tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  UserSsoLink   UserSsoLink[]

  @@unique([tenantId, issuer])
  @@index([tenantId, enabled])
  @@map("sso_providers")
}

model UserSsoLink {
  id            String      @id @default(cuid())
  userId        String      @map("user_id")
  providerId    String      @map("provider_id")
  externalId    String      @map("external_id") // Subject/NameID from IdP
  externalEmail String?     @map("external_email")
  metadata      Json? // Additional IdP claims
  linkedAt      DateTime    @default(now()) @map("linked_at")
  lastLoginAt   DateTime?   @map("last_login_at")
  User          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  SsoProvider   SsoProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, externalId])
  @@index([userId])
  @@map("user_sso_links")
}

enum SsoProtocol {
  SAML2
  OIDC
}
