generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AIMetric {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  resource  String?
  value     Decimal
  metadata  Json?
  createdAt DateTime @default(now())
  Tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, name])
}

model AiAgentLog {
  id             String         @id @default(cuid())
  agentId        String
  type           String
  payload        Json
  createdAt      DateTime       @default(now())
  AiAgentProfile AiAgentProfile @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model AiAgentProfile {
  id           String       @id @default(cuid())
  userId       String?
  name         String
  contextMap   Json         @default("{}")
  lastActivity DateTime     @default(now())
  status       AgentStatus  @default(ACTIVE)
  AiAgentLog   AiAgentLog[]
}

model AiProctoringResult {
  id               String      @id @default(cuid())
  sessionId        String
  eyeScore         Float?
  headScore        Float?
  audioScore       Float?
  tabSwitches      Int?
  objectFlags      Int?
  finalTrustScore  Float?
  aiRecommendation String?
  createdAt        DateTime    @default(now())
  ExamSession      ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model AsyncExport {
  id        String   @id @default(cuid())
  type      String
  status    String   @default("PROCESSING")
  filePath  String?
  actorId   String?
  tenantId  String   @default("public")
  createdAt DateTime @default(now())
  Tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String?
  entityId  String?
  meta      Json?
  ip        String?
  ua        String?
  createdAt DateTime @default(now())
  User      User?    @relation(fields: [actorId], references: [id])
}

model BiometricHash {
  id        String   @id @default(cuid())
  userId    String
  faceHash  String?
  voiceHash String?
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Certification {
  id               String              @id @default(cuid())
  userId           String
  courseId         String
  issuedAt         DateTime            @default(now())
  expiresAt        DateTime?
  status           CertificationStatus @default(ACTIVE)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  examSessionId    String?             @unique
  verifyCode       String?             @unique
  blockchainStatus String?
  sbtTokenId       String?
  Course           Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  ExamSession      ExamSession?        @relation(fields: [examSessionId], references: [id])
  User             User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([userId, status])
}

model Class {
  id           String      @id @default(cuid())
  tenantId     String      @default("public")
  name         String      @default("Demo Class")
  instructorId String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  courseId     String?
  departmentId String?
  Course       Course?     @relation(fields: [courseId], references: [id])
  User         User        @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  Department   Department? @relation(fields: [departmentId], references: [id])

  @@index([courseId])
  @@index([instructorId])
  @@index([tenantId])
}

model CognitiveLoad {
  id              String         @id @default(cuid())
  userId          String
  lessonId        String
  attentionScore  Float?
  confusionIndex  Float?
  recordedAt      DateTime       @default(now())
  Lesson          LessonContent  @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  User            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  LessonBooking   LessonBooking? @relation(fields: [lessonBookingId], references: [id])
  lessonBookingId String?

  @@index([userId, lessonId, recordedAt])
}

model CommunicationMessage {
  id          String      @id @default(cuid())
  sessionId   String
  senderId    String
  type        MessageType @default(CHAT)
  content     String
  metadata    Json?
  createdAt   DateTime    @default(now())
  role        Role
  User        User        @relation(fields: [senderId], references: [id], onDelete: Cascade)
  LiveSession LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

// ─── Coursera & Udacity Stili Ödev ve Akran Değerlendirme (Peer Review) ───

model Assignment {
  id             String                 @id @default(cuid())
  courseId       String
  title          String
  description    String?
  dueDate        DateTime
  isPeerReviewed Boolean                @default(false) // Coursera Stili Akran Değerlendirmesi
  createdAt      DateTime               @default(now())
  Course         Course                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  Submissions    AssignmentSubmission[]
}

model AssignmentSubmission {
  id           String       @id @default(cuid())
  assignmentId String
  userId       String
  contentUrl   String // Ödev dosyası PDF vb.
  grade        Float?
  submittedAt  DateTime     @default(now())
  Assignment   Assignment   @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  User         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  PeerReviews  PeerReview[]

  @@unique([assignmentId, userId])
}

model PeerReview {
  id           String               @id @default(cuid())
  submissionId String
  reviewerId   String
  score        Float
  feedback     String?
  createdAt    DateTime             @default(now())
  Submission   AssignmentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  Reviewer     User                 @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

  @@unique([submissionId, reviewerId])
}

model Course {
  id                 String               @id @default(cuid())
  title              String
  description        String?
  isPublished        Boolean              @default(false)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  instructorId       String?
  price              Decimal              @default(0)
  tenantId           String               @default("public")
  Certification      Certification[]
  Class              Class[]
  User               User?                @relation(fields: [instructorId], references: [id])
  Tenant             Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  CourseSchedule     CourseSchedule[]
  Enrollment         Enrollment[]
  ExamSession        ExamSession[]
  LearningPlanCourse LearningPlanCourse[]
  Lesson             LessonContent[]
  CourseMaterial     CourseMaterial[] // AÖF E-Kampüs Materyalleri (PDF, Sesli Kitap, Çıkmış Sorular)
  LiveSession        LiveSession[]
  LtiDeployment      LtiDeployment[]
  PaymentIntent      PaymentIntent[]
  StreamMetric       StreamMetric[]
  VolunteerContent   VolunteerContent[]
  LessonBooking      LessonBooking[]
  LessonProgress     LessonProgress[]
  TeamProject        TeamProject[]
  StudentRiskProfile StudentRiskProfile[]
  Assignment         Assignment[]
}

model CourseSchedule {
  id            String       @id @default(cuid())
  courseId      String
  title         String
  description   String?
  startAt       DateTime
  endAt         DateTime
  timezone      String?
  location      String?
  meetingUrl    String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  liveSessionId String?
  Course        Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  LiveSession   LiveSession? @relation(fields: [liveSessionId], references: [id])

  @@index([courseId, startAt])
}

model CustomerSignal {
  id          String   @id @default(cuid())
  tenantId    String
  companyName String
  segment     String
  userCount   Int
  vertical    String?
  status      String   @default("prospect")
  lastContact DateTime
  score       Decimal  @default(0)
  metadata    Json
  createdAt   DateTime @default(now())
  Tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, score])
  @@index([tenantId, status])
}

model DefenseAction {
  id            String             @id @default(cuid())
  eventId       String?
  actionType    DefenseActionType
  target        String?
  params        Json?
  state         DefenseActionState @default(PROPOSED)
  reason        String?
  createdBy     String?
  createdAt     DateTime           @default(now())
  appliedAt     DateTime?
  rolledBackAt  DateTime?
  SecurityEvent SecurityEvent?     @relation(fields: [eventId], references: [id])

  @@index([actionType, state])
  @@index([eventId])
}

model DocumentSequence {
  id        String   @id @default(cuid())
  docType   String   @unique
  year      Int
  counter   Int      @default(0)
  updatedAt DateTime @updatedAt
}

model Enrollment {
  id          String    @id @default(cuid())
  userId      String
  courseId    String
  createdAt   DateTime  @default(now())
  completedAt DateTime?
  refundedAt  DateTime?
  tenantId    String    @default("public")
  Course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  Tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  User        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([completedAt])
  @@index([courseId])
  @@index([refundedAt])
  @@index([userId])
}

model ExamSession {
  id                 String               @id @default(cuid())
  userId             String
  courseId           String
  startedAt          DateTime             @default(now())
  endedAt            DateTime?
  deviceInfo         Json?
  trustScore         Float?
  aiDecision         String?
  proctorNote        String?
  createdAt          DateTime             @default(now())
  AiProctoringResult AiProctoringResult[]
  Certification      Certification?
  Course             Course               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  User               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, courseId])
}

model InstructorAction {
  id                                       String    @id @default(cuid())
  classId                                  String
  createdById                              String
  targetType                               String
  targetUserId                             String?
  actionType                               String
  payload                                  Json      @default("{}")
  status                                   String    @default("active")
  dueAt                                    DateTime?
  createdAt                                DateTime  @default(now())
  updatedAt                                DateTime  @updatedAt
  tenantId                                 String?   @default("public")
  User_InstructorAction_createdByIdToUser  User      @relation("InstructorAction_createdByIdToUser", fields: [createdById], references: [id], onDelete: Cascade)
  User_InstructorAction_targetUserIdToUser User?     @relation("InstructorAction_targetUserIdToUser", fields: [targetUserId], references: [id])

  @@index([classId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([tenantId, createdAt])
}

model InstructorPayment {
  id                                        String                  @id @default(cuid())
  instructorId                              String
  periodStart                               DateTime
  periodEnd                                 DateTime
  completedEnrollments                      Int
  refundCount                               Int
  courseRevenue                             Decimal                 @default(0)
  amount                                    Decimal                 @default(0)
  details                                   Json?
  notes                                     String?
  status                                    InstructorPaymentStatus @default(PENDING)
  recordedById                              String?
  createdAt                                 DateTime                @default(now())
  updatedAt                                 DateTime                @updatedAt
  paidAt                                    DateTime?
  User_InstructorPayment_instructorIdToUser User                    @relation("InstructorPayment_instructorIdToUser", fields: [instructorId], references: [id], onDelete: Cascade)
  User_InstructorPayment_recordedByIdToUser User?                   @relation("InstructorPayment_recordedByIdToUser", fields: [recordedById], references: [id])

  @@unique([instructorId, periodStart, periodEnd])
  @@index([instructorId, status])
  @@index([periodStart, periodEnd])
}

model InstructorPayoutProfile {
  id               String   @id @default(cuid())
  instructorId     String
  level            String?
  baseFee          Decimal  @default(0)
  perEnrollmentFee Decimal  @default(0)
  revenueShare     Decimal  @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  User             User     @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@index([instructorId])
}

model InstructorValueScore {
  id                                           String   @id @default(cuid())
  instructorId                                 String
  approvedContents                             Int      @default(0)
  feedbackCount                                Int      @default(0)
  averageRating                                Decimal  @default(0)
  score                                        Decimal  @default(0)
  computedAt                                   DateTime @default(now())
  recordedById                                 String?
  User_InstructorValueScore_instructorIdToUser User     @relation("InstructorValueScore_instructorIdToUser", fields: [instructorId], references: [id], onDelete: Cascade)
  User_InstructorValueScore_recordedByIdToUser User?    @relation("InstructorValueScore_recordedByIdToUser", fields: [recordedById], references: [id])

  @@index([computedAt])
  @@index([instructorId])
}

model IntegrationConnector {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  provider  String
  type      String
  config    Json
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
}

model LearningEvent {
  id        String            @id @default(cuid())
  tenantId  String
  userId    String?
  eventType LearningEventType
  payload   Json?
  createdAt DateTime          @default(now())
  Tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  User      User?             @relation(fields: [userId], references: [id])

  @@index([tenantId, eventType])
  @@index([userId])
}

model LearningPlan {
  id                 String               @id @default(cuid())
  name               String
  description        String?
  isActive           Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  LearningPlanCourse LearningPlanCourse[]
}

model LearningPlanCourse {
  id             String       @id @default(cuid())
  learningPlanId String
  courseId       String
  createdAt      DateTime     @default(now())
  Course         Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  LearningPlan   LearningPlan @relation(fields: [learningPlanId], references: [id], onDelete: Cascade)

  @@unique([learningPlanId, courseId])
  @@index([courseId])
}

model LessonContent {
  id             String           @id @default(cuid())
  courseId       String
  title          String
  order          Int              @default(0)
  videoUrl       String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  content        String?
  isPreview      Boolean          @default(false)
  CognitiveLoad  CognitiveLoad[]
  Course         Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  StreamMetric   StreamMetric[]
  LessonProgress LessonProgress[]

  @@unique([courseId, order])
  @@index([courseId])
  @@map("lessons")
}

// AÖF E-Kampüs Stili Ders Materyalleri (Çıkmış Sorular, Ünite Özetleri vb.)
model CourseMaterial {
  id          String       @id @default(cuid())
  courseId    String
  title       String
  description String?
  type        MaterialType @default(PDF) // PDF, AUDIOBOOK, SLIDE, PAST_EXAM
  url         String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  Course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

enum MaterialType {
  PDF
  AUDIOBOOK
  SLIDE
  PAST_EXAM
}

model LiveSession {
  id                     String                   @id @default(cuid())
  courseId               String
  instructorId           String
  topic                  String?
  status                 LiveSessionStatus        @default(SCHEDULED)
  isRecording            Boolean                  @default(false)
  activeSpeakerId        String?
  startedAt              DateTime?
  endedAt                DateTime?
  metadata               Json?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  CommunicationMessage   CommunicationMessage[]
  CourseSchedule         CourseSchedule[]
  Course                 Course                   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  User                   User                     @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  LiveSessionParticipant LiveSessionParticipant[]
  PresentationRequest    PresentationRequest[]
  WhiteboardSession      WhiteboardSession?
  SmartClassroom         SmartClassroom?
  LiveSessionBreakout    LiveSessionBreakout[]

  @@index([courseId, status])
}

// ─── Canlı Ders Alt Çalışma Odaları (Breakout Rooms) ───────────────────────
model LiveSessionBreakout {
  id            String                   @id @default(cuid())
  liveSessionId String
  name          String // Örn: "Oda 1", "Oda 2"
  maxCapacity   Int                      @default(5)
  createdAt     DateTime                 @default(now())
  LiveSession   LiveSession              @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  Participants  LiveSessionParticipant[] // Odaya atanmış öğrenciler
}

model LiveSessionParticipant {
  id                  String               @id @default(cuid())
  sessionId           String
  userId              String
  micOn               Boolean              @default(false)
  cameraOn            Boolean              @default(false)
  screenShare         Boolean              @default(false)
  breakoutRoomId      String?
  joinedAt            DateTime             @default(now())
  role                Role
  LiveSession         LiveSession          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  User                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  LiveSessionBreakout LiveSessionBreakout? @relation(fields: [breakoutRoomId], references: [id], onDelete: SetNull)

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@index([breakoutRoomId])
}

// Legacy / booking lessons and live rooms
model LessonBooking {
  id             String   @id @default(uuid())
  instructorId   String   @map("instructor_id")
  studentId      String   @map("student_id")
  scheduledStart DateTime @map("scheduled_start")
  scheduledEnd   DateTime @map("scheduled_end")
  status         String   @default("scheduled")
  meetingLink    String?  @map("meeting_link")
  createdAt      DateTime @default(now()) @map("created_at")

  instructor    User            @relation("LessonInstructor", fields: [instructorId], references: [id], onDelete: Cascade)
  student       User            @relation("LessonStudent", fields: [studentId], references: [id], onDelete: Cascade)
  CognitiveLoad CognitiveLoad[]
  Course        Course?         @relation(fields: [courseId], references: [id])
  courseId      String?
  StreamMetric  StreamMetric[]

  @@index([instructorId])
  @@index([studentId])
  @@index([scheduledStart])
  @@map("lessons_booking")
}

model LiveSessionLegacy {
  id           String    @id @default(uuid())
  instructorId String    @map("instructor_id")
  classCode    String    @unique @map("class_code")
  language     String
  targetLevel  String    @map("target_level")
  status       String    @default("live")
  startedAt    DateTime  @default(now()) @map("started_at")
  endedAt      DateTime? @map("ended_at")

  instructor    User           @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  breakoutRooms BreakoutRoom[]
  attendance    Attendance[]

  @@map("live_sessions")
}

model BreakoutRoom {
  id        String   @id @default(uuid())
  sessionId String   @map("session_id")
  roomName  String   @map("room_name")
  createdAt DateTime @default(now()) @map("created_at")

  liveSession LiveSessionLegacy @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("breakout_rooms")
}

model Attendance {
  id        String    @id @default(uuid())
  sessionId String    @map("session_id")
  studentId String    @map("student_id")
  joinTime  DateTime  @default(now()) @map("join_time")
  leaveTime DateTime? @map("leave_time")
  totalXp   Int       @default(0) @map("total_xp_earned")

  liveSession LiveSessionLegacy @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student     User              @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([studentId])
  @@map("attendance_records")
}

model LtiDeployment {
  id          String           @id @default(cuid())
  toolId      String
  courseId    String
  instructors String[]
  learners    String[]
  status      DeploymentStatus @default(ACTIVE)
  keyRotation DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  Course      Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  LtiTool     LtiTool          @relation(fields: [toolId], references: [id], onDelete: Cascade)
  LtiLaunch   LtiLaunch[]
}

model LtiLaunch {
  id            String        @id @default(cuid())
  deploymentId  String
  userId        String
  role          String
  rawPayload    Json
  createdAt     DateTime      @default(now())
  LtiDeployment LtiDeployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
}

model LtiTool {
  id            String          @id @default(cuid())
  name          String
  description   String?
  issuer        String
  clientId      String          @unique
  publicKey     String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  LtiDeployment LtiDeployment[]
}

model PaymentIntent {
  id                String        @id @default(cuid())
  provider          String
  providerPaymentId String?
  amount            Decimal
  currency          String        @default("USD")
  status            PaymentStatus @default(PENDING)
  userId            String?
  tenantId          String?
  courseId          String?
  planId            String?
  seats             Int?
  installments      Int?
  metadata          Json?
  paidAt            DateTime?
  createdAt         DateTime      @default(now())
  Course            Course?       @relation(fields: [courseId], references: [id])
  PricePlan         PricePlan?    @relation(fields: [planId], references: [id])
  User              User?         @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId, status])
}

model PerformanceSnapshot {
  id         String   @id @default(cuid())
  userId     String?
  role       Role?
  context    String?
  metrics    Json
  notes      String?
  recordedAt DateTime @default(now())

  @@index([recordedAt])
  @@index([role])
}

model PresentationRequest {
  id          String             @id @default(cuid())
  sessionId   String
  requesterId String
  status      PresentationStatus @default(PENDING)
  requestedAt DateTime           @default(now())
  respondedAt DateTime?
  notes       String?
  User        User               @relation(fields: [requesterId], references: [id], onDelete: Cascade)
  LiveSession LiveSession        @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, status])
}

model PricePlan {
  id            String          @id @default(cuid())
  name          String
  type          String          @default("BASE_PLAN") // BASE_PLAN, MODULE_ADDON
  amount        Decimal
  currency      String          @default("USD")
  interval      String? // monthly, yearly, lifetime
  courseId      String?
  features      Json? // {"LIVE_CLASSES": true, "AI_GHOST_MENTOR": false}
  createdAt     DateTime        @default(now())
  PaymentIntent PaymentIntent[]
  Subscription  Subscription[]
}

model PricingProposal {
  id         String   @id @default(cuid())
  tenantId   String
  amount     Decimal
  currency   String   @default("USD")
  confidence Decimal  @default(0)
  reason     String
  createdAt  DateTime @default(now())
  Tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model PricingRule {
  id            String   @id @default(cuid())
  tenantId      String
  name          String
  basePerUser   Decimal
  minUsers      Int      @default(1)
  maxUsers      Int?
  moduleSupport Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  Tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
}

model Recommendation {
  id           String             @id @default(cuid())
  tenantId     String
  userId       String?
  type         RecommendationType
  payload      Json
  reason       String
  score        Decimal
  context      Json?
  createdAt    DateTime           @default(now())
  explainedBy  String?
  modelVersion String?
  Tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  User         User?              @relation(fields: [userId], references: [id])
}

model ScheduledReport {
  id          String                   @id @default(cuid())
  name        String
  reportType  String                   @default("USERS")
  format      ScheduledReportFormat    @default(PDF)
  filters     Json?
  recipients  Json
  frequency   ScheduledReportFrequency
