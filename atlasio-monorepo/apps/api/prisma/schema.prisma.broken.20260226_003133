model Class {
  id           String   @id
  tenantId     String   @default("public")
  name         String   @default("Demo Class")
  instructorId String
  instructor   User     @relation(fields: [instructorId], references: [id])
  courseId     String?
  course       Course?  @relation(fields: [courseId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  actions      InstructorAction[]

  @@index([tenantId])
  @@index([instructorId])
  @@index([courseId])
  @@map("Class")
}

model InstructorAction {
  id           String   @id @default(cuid())
  tenantId     String   @default("public")
  classId      String
  class        Class    @relation(fields: [classId], references: [id])

  createdById  String
  createdBy    User     @relation(fields: [createdById], references: [id])

  targetType   String
  targetUserId String?
  targetUser   User?    @relation(fields: [targetUserId], references: [id])

  actionType   String
  payload      Json     @default("{}")
  status       String   @default("active")
  dueAt        DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([classId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([tenantId, createdAt])
  @@map("InstructorAction")
}
